<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.curtis.guts-radio</string>

  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/node</string>
    <string>/Users/doorliss/timeclaw/whatsapp-watcher/radio/sync.js</string>
    <string>--no-backfill</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/doorliss/timeclaw/whatsapp-watcher/radio</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>HOME</key>
    <string>/Users/doorliss</string>
  </dict>

  <!-- Don't fire on system boot. Lets the watcher come up first; we run on
       interval. -->
  <key>RunAtLoad</key>
  <false/>

  <!-- Every 30 minutes. We use --no-backfill here because the watcher captures
       new messages live; backfill is only needed for one-time history pulls.
       To force a fresh history pull manually:
         launchctl bootout gui/$(id -u)/com.curtis.whatsapp-watcher
         node /Users/doorliss/timeclaw/whatsapp-watcher/radio/sync.js
       (sync.js will pause/resume the watcher itself.) -->
  <key>StartInterval</key>
  <integer>1800</integer>

  <key>ThrottleInterval</key>
  <integer>60</integer>

  <key>StandardOutPath</key>
  <string>/Users/doorliss/timeclaw/whatsapp-watcher/logs/guts-radio.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/doorliss/timeclaw/whatsapp-watcher/logs/guts-radio.err.log</string>
</dict>
</plist>
